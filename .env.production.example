# Core
DEBUG=False
DJANGO_SECRET_KEY=
ENABLE_DEBUG_TOOLBAR=False
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Replace domains with the final Selectel/Nginx hostnames.
ALLOWED_HOSTS=api.example.com
CSRF_TRUSTED_ORIGINS=https://api.example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com
CORS_ALLOW_ALL_ORIGINS=False

# PostgreSQL. Use either DATABASE_URL or DB_*.
DATABASE_URL=
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# Redis / Celery / Channels
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_URL=redis://redis:6379/1
CHANNEL_REDIS_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_LOG_LEVEL=info

# Email: production default backend is Anymail Unisender Go.
EMAIL_BACKEND=anymail.backends.unisender_go.EmailBackend
EMAIL_USER=
DEFAULT_FROM_EMAIL=
UNISENDER_GO_API_KEY=
FRONTEND_URL=https://app.example.com
SITE_URL=https://app.example.com

# Production file storage.
FILE_STORAGE=selectel
LOCAL_MEDIA_BASE_URL=https://api.example.com
SELECTEL_ACCOUNT_ID=
SELECTEL_CONTAINER_NAME=
SELECTEL_CONTAINER_PASSWORD=
SELECTEL_CONTAINER_USERNAME=

# Optional integrations
SENTRY_DSN=
AUTOPOSTING_ON=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_NOTIFICATIONS_ENABLED=False
TELEGRAM_ADMIN_CHAT_IDS=
CLICKUP_API_TOKEN=
CLICKUP_SPACE_ID=
