# Core
DEBUG=True
DJANGO_SECRET_KEY=django-insecure-local-dev-key
ENABLE_DEBUG_TOOLBAR=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Hosts / browser security
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:4200,http://127.0.0.1:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
CORS_ALLOW_ALL_ORIGINS=False

# Database. Local default is SQLite if DB_ENGINE/DATABASE_URL are empty.
DB_ENGINE=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432
DATABASE_URL=
SQLITE_NAME=

# Backward-compatible names used by existing compose/CI scripts.
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=
DATABASE_PORT=5432
POSTGRES_HOST_PORT=5432

# Redis / Celery / Channels
REDIS_URL=
REDIS_HOST=
REDIS_CACHE_URL=
CHANNEL_REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_LOG_LEVEL=info

# Email. Console backend is convenient for local dev.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_USER=
DEFAULT_FROM_EMAIL=
UNISENDER_GO_API_KEY=
FRONTEND_URL=http://127.0.0.1:4200
SITE_URL=http://127.0.0.1:4200

# File storage: local or selectel.
FILE_STORAGE=local
LOCAL_MEDIA_BASE_URL=http://127.0.0.1:8000
SELECTEL_ACCOUNT_ID=
SELECTEL_CONTAINER_NAME=
SELECTEL_CONTAINER_PASSWORD=
SELECTEL_CONTAINER_USERNAME=

# Optional integrations
SENTRY_DSN=
AUTOPOSTING_ON=False
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_NOTIFICATIONS_ENABLED=False
TELEGRAM_PROXY_URL=
TELEGRAM_ADMIN_CHAT_IDS=
CLICKUP_API_TOKEN=
CLICKUP_SPACE_ID=
